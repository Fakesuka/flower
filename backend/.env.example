# Server Configuration
PORT=3001
NODE_ENV=development

# Telegram Bot Tokens
# Customer bot - for sending notifications to customers
CUSTOMER_BOT_TOKEN=your_customer_bot_token_here

# Florist bot - for receiving orders and managing them
FLORIST_BOT_TOKEN=your_florist_bot_token_here

# Florist Chat IDs (comma-separated list of Telegram chat IDs)
# These are the florists who will receive order notifications
FLORIST_CHAT_IDS=123456789,987654321

# Telegram WebApp
# Your bot username (for WebApp validation)
TELEGRAM_BOT_USERNAME=your_bot_username

# Payment Configuration
# Payment URL that customers will be sent to for payment
PAYMENT_URL=https://your-payment-provider.com/pay

# Review Links (shown to customers after delivery)
YANDEX_MAPS_URL=https://yandex.ru/maps/org/your_flower_shop_id
TWOGIS_URL=https://2gis.ru/firm/your_flower_shop_id

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Optional: Database path (defaults to ./data/database.sqlite)
# DB_PATH=./data/database.sqlite
